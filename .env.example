# ─── CarbonTrace MRV Platform — Environment Variables ────────────────────────
# Copy this file to .env and fill in the values

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=carbontrace
DB_PASSWORD=carbontrace_dev
DB_NAME=carbontrace_db
DB_NAME_TEST=carbontrace_test

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001
FRONTEND_A_URL=http://localhost:3000
FRONTEND_B_URL=http://localhost:3001

# ─── JWT Authentication ─────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ─── Blockchain (Ethereum Sepolia) ───────────────────────────────────────────
SEPOLIA_RPC_URL=https://rpc.sepolia.org
DEPLOYER_PRIVATE_KEY=your-deployer-private-key
SEPOLIA_CHAIN_ID=11155111
LAND_REGISTRY_ADDRESS=
CARBON_CREDIT_MANAGER_ADDRESS=

# ─── Razorpay ───────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── IPFS (Pinata) ──────────────────────────────────────────────────────────
PINATA_API_KEY=your-pinata-api-key
PINATA_API_SECRET=your-pinata-api-secret

# ─── ISRO Bhuvan API ────────────────────────────────────────────────────────
BHUVAN_API_KEY=your-bhuvan-api-key

# ─── Firebase Cloud Messaging ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ─── Dialogflow (Chatbot) ───────────────────────────────────────────────────
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id

# ─── Carbon Credit Config ───────────────────────────────────────────────────
PRICE_PER_CREDIT=1500
SEQUESTRATION_RATE=7.5
TCO2_PER_CREDIT=1
DEFAULT_SURVIVAL_RATE=0.85
